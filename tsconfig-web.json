{
  "compilerOptions": {
    "baseUrl": "src/js",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["dom", "es2021"],
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react"
  },
  "include": ["src/**/*", "assets/**/*.json", "assets/**/*"],
  "exclude": ["./fetch_assets"],
  "references": [{ "path": "./common/tsconfig.json" }],
  "extends": ["./tsconfig-base.json"]
}
